# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
ENABLE_GROUP_CHATS=false
TELEGRAM_ALLOWED_CHAT_IDS=

# Codex/local machine
# Leave CODEX_BIN empty when `codex` is already on PATH. Otherwise set an
# absolute path to the Codex executable.
CODEX_BIN=
CODEX_HOME=
CODEX_SESSION_BACKEND=app-server
CODEX_WORKSPACE=

# Comma-separated absolute paths. The bridge rejects control/write access
# outside these roots.
ALLOWED_PROJECT_ROOTS=

# Optional read-only monitoring roots for /active and /watch. This does not
# allow launching or editing there. Defaults to ALLOWED_PROJECT_ROOTS when empty.
MONITORED_PROJECT_ROOTS=

# Defaults for new sessions
CODEX_MODEL=
CODEX_SANDBOX_MODE=workspace-write
CODEX_APPROVAL_POLICY=on-request
CODEX_DEFAULT_LAUNCH_PROFILE=default
ENABLE_UNSAFE_LAUNCH_PROFILES=false

# Optional auth and output features
CODEX_API_KEY=
OPENAI_API_KEY=
MAX_FILE_SIZE=
CODEX_LAUNCH_PROFILES_JSON=
ENABLE_VOICE_INPUT=false
ENABLE_FILE_UPLOADS=false
AUTO_SEND_ARTIFACTS=false
ENABLE_TELEGRAM_LOGIN=false
ENABLE_TELEGRAM_REACTIONS=false
SHOW_ASSISTANT_OUTPUT_IN_TELEGRAM=false
SHOW_ERROR_DETAILS_IN_TELEGRAM=false
TOOL_VERBOSITY=summary
SHOW_TURN_TOKEN_USAGE=false
LOG_LEVEL=info
